{
  "name": "@nmipayments/nmi-pay",
  "version": "1.0.2",
  "description": "NMI Embedded Component for Payments",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css",
    "dist/index.js",
    "dist/nmi-payments-cdn.iife.js",
    "src/gatewayjs/gateway.js",
    "src/NmiPayWidget.svelte",
    "src/NmiThreeDSecureWidget.svelte"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nmipayments/nmi-core": "^1.0.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.15.17",
    "eslint": "^9.17.0",
    "rimraf": "^5.0.5",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.3.0",
    "rollup-plugin-terser": "^7.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build:dev": "vite build --mode development && BUILD_IIFE=true vite build --mode development",
    "build": "tsc --noEmit && vite build && BUILD_IIFE=true vite build",
    "build:grey": "tsc --noEmit && BUILD_PACKAGE_SCOPE=@pmt-nblmt BUILD_PACKAGE_PREFIX=pe vite build --mode grey && BUILD_IIFE=true BUILD_PACKAGE_SCOPE=@pmt-nblmt BUILD_PACKAGE_PREFIX=pe vite build --mode grey && BUILD_PACKAGE_SCOPE=@pmt-nblmt BUILD_PACKAGE_PREFIX=pe node ../../scripts/grey-rename-dts.js dist",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts"
  }
}