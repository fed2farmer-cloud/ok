{
  "name": "@nmipayments/nmi-core",
  "version": "1.0.2",
  "description": "NMI Embedded Components Core Utilities",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "eslint": "^9.17.0",
    "rimraf": "^5.0.5",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.3.0",
    "rollup-plugin-terser": "^7.0.2"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build:dev": "vite build --mode development",
    "build": "tsc --noEmit && vite build && tsc --emitDeclarationOnly",
    "build:grey": "tsc --noEmit && BUILD_PACKAGE_PREFIX=pe vite build && tsc --emitDeclarationOnly && BUILD_PACKAGE_SCOPE=@pmt-nblmt BUILD_PACKAGE_PREFIX=pe node ../../scripts/grey-rename-dts.js dist",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts,.tsx"
  }
}