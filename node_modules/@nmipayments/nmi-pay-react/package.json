    "@types/cypress-axe": "^0.11.3",
    "@types/mocha": "^10.0.1",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.10.3",
    "cypress": "^14.0.0",
    "cypress-axe": "^1.6.0",
    "cypress-real-events": "^1.11.0",
