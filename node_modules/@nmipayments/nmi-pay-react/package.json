  "dependencies": {
    "@nmipayments/nmi-pay": "^1.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build:dev": "vite build --mode development",
    "build": "tsc --noEmit && vite build",
    "build:grey": "tsc --noEmit && BUILD_PACKAGE_SCOPE=@pmt-nblmt BUILD_PACKAGE_PREFIX=pe vite build && BUILD_PACKAGE_SCOPE=@pmt-nblmt BUILD_PACKAGE_PREFIX=pe node ../../scripts/grey-rename-dts.js dist",
    "clean": "rimraf dist",
    "test": "cypress run --component --browser chrome",
    "cy:open-unit": "cypress open --component --browser chrome",
    "cy:run-unit": "cypress run --component --browser chrome"
  }
